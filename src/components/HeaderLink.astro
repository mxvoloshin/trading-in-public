---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const stripBase = (value = '') => value.replace(base, '').replace(/^\/|\/$/g, '');
const currentPath = stripBase(Astro.url.pathname);
const targetPath = stripBase(href);
const isActive =
	currentPath === targetPath || (targetPath.length > 0 && currentPath.split('/')[0] === targetPath);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>

---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroImage from '../assets/trade-in-public-hero.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={HeroImage} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">Automated trading as a software project</p>
					<h1>{SITE_TITLE}</h1>
					<p>
						A public build log for designing, validating, and operating an automated trading system
						with the same discipline I would use for any serious software product.
					</p>
					<div class="actions">
						<a class="button" href={`${base}blog/`}>Read the blog</a>
						<a href="https://github.com/mxvoloshin/trading-in-public">View the public repo</a>
					</div>
				</div>
				<img
					src={HeroImage.src}
					width={HeroImage.width}
					height={HeroImage.height}
					alt="A laptop and notebook showing abstract code and market-chart research"
				/>
			</section>
			<section class="principles" aria-label="Project principles">
				<div>
					<h2>What This Tracks</h2>
					<p>
						Broker/API decisions, Python implementation notes, backtesting lessons, safety gates,
						deployment notes, and honest reviews of what worked or broke.
					</p>
				</div>
				<div>
					<h2>Ground Rules</h2>
					<p>
						No signals, no hype, no real-time recommendations, no sensitive broker details. This is a
						personal engineering journal, not financial advice.
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.home {
		width: 1080px;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
		gap: 2.5rem;
		align-items: center;
	}
	.hero-copy {
		max-width: 620px;
	}
	.eyebrow {
		margin: 0 0 0.75rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	.hero h1 {
		margin-bottom: 1rem;
		font-size: 3rem;
	}
	.hero img {
		aspect-ratio: 16 / 9;
		object-fit: cover;
		box-shadow: var(--box-shadow);
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
		margin-top: 1.5rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 0 1rem;
		border-radius: 6px;
		background: var(--accent);
		color: white;
		font-weight: 700;
		text-decoration: none;
	}
	.button:hover {
		color: white;
		background: var(--accent-dark);
	}
	.principles {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.principles h2 {
		font-size: 1.4rem;
	}
	@media (max-width: 840px) {
		.home {
			width: 720px;
		}
		.hero,
		.principles {
			grid-template-columns: 1fr;
		}
		.hero h1 {
			font-size: 2.4rem;
		}
	}
</style>
